		"test": "playwright test",
		"test:ui": "playwright test --ui",
		"test:headed": "playwright test --headed",
		"test:report": "playwright show-report",
		"test:auth": "playwright test e2e/01-auth.spec.ts",
		"test:chat": "playwright test e2e/02-chat.spec.ts",
		"test:knowledge": "playwright test e2e/03-knowledge.spec.ts",
		"test:admin": "playwright test e2e/04-admin-dashboard.spec.ts e2e/05-admin-repos.spec.ts e2e/06-admin-documents.spec.ts e2e/07-admin-users.spec.ts",
